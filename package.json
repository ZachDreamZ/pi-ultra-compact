{
  "name": "pi-ultra-compact",
  "version": "1.2.0",
  "description": "Advanced compaction extension and skill for Pi with automatic threshold-based compaction and critical context preservation",
  "keywords": [
    "pi-package",
    "compaction",
    "compression",
    "ultra-compact",
    "context-management",
    "token-savings"
  ],
  "author": "Vendex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZachDreamZ/pi-ultra-compact.git"
  },
  "homepage": "https://github.com/ZachDreamZ/pi-ultra-compact#readme",
  "bugs": {
    "url": "https://github.com/ZachDreamZ/pi-ultra-compact/issues"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"extensions/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --check \"extensions/**/*.ts\" \"tests/**/*.ts\""
  },
  "files": [
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
