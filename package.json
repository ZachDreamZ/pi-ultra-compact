{
  "name": "pi-ultra-compact",
  "version": "0.9.1",
  "description": "Advanced compaction extension and skill for Pi with automatic threshold-based compaction and critical context preservation",
  "keywords": [
    "pi-package",
    "compaction",
    "compression",
    "ultra-compact",
    "context-management",
    "token-savings"
  ],
  "author": "Vendex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZachDreamZ/pi-ultra-compact.git"
  },
  "homepage": "https://github.com/ZachDreamZ/pi-ultra-compact#readme",
  "bugs": {
    "url": "https://github.com/ZachDreamZ/pi-ultra-compact/issues"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.75.0",
    "@earendil-works/pi-coding-agent": "^0.75.0",
    "@earendil-works/pi-tui": "^0.75.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.3",
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@earendil-works/pi-tui": "^0.79.3",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint extensions/ tests/",
    "lint:fix": "eslint extensions/ tests/ --fix",
    "format": "prettier --write extensions/ tests/",
    "format:check": "prettier --check extensions/ tests/"
  },
  "files": [
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
